<style>
    input#CompanyName {
        color: gray;
        padding: 6px 12px;
        border: 1px solid #cccccc;
        border-radius: 4px;
    }

    .k-grid tbody tr {
        height: 45px !important;
    }

    .k-grid td {
        white-space: nowrap !important;
        text-overflow: ellipsis !important;
        vertical-align: middle !important;
        padding-top: 5px !important;
        padding-bottom: 5px !important;
    }

    .nav-tabs > li.active > a, .nav-tabs > li.active > a:focus, .nav-tabs > li.active > a:hover {
        background-color: #f5f5f5;
        font-weight: bold;
        color: #31708f;
        border-bottom-color: transparent;
    }

    .tab-content {
        padding: 15px;
        background: #fff;
        border: 1px solid #ddd;
        border-top: none;
    }
</style>

<script type="text/javascript">
    function AllowNumbersOnly(e) {
        var code = (e.which) ? e.which : e.keyCode;
        if (code > 31 && (code < 48 || code > 57)) { e.preventDefault(); }
    }

    function getSearchParameters() {
        return {
            InvoiceNumber: $("input#InvoiceNumber").val(),
            BuyerMobile: $("input#BuyerMobile").val(),
            ProductName: $("select#ProductName").val(),
            FactoryName: $("select#FactoryName").val(),
            Province: $("select#Province").val(),
            City: $("select#City").val(),
            RequestState: $("select#RequestState").val(),
            StartDate: $("input#StartDate").val(),
            EndDate: $("input#EndDate").val()
        };
    }

    var rowNumber1 = 0, rowNumber2 = 0, rowNumber3 = 0;
    var isGrid2Loaded = false;
    var isGrid3Loaded = false;

    // 🌟 متغیرهای جدید برای ذخیره زمان آخرین لود هر گرید
    var lastLoadTime1 = Date.now(); // گرید ۱ در ابتدا لود می‌شود
    var lastLoadTime2 = 0;
    var lastLoadTime3 = 0;

    // 🌟 زمان انقضای دیتا (مثلاً ۲ دقیقه = 120,000 میلی‌ثانیه)
    var cacheExpirationMs = 2 * 60 * 1000;

    $(document).ready(function () {
        $('#StartDate').datepicker({ dateFormat: 'yy/mm/dd', autoSize: true, showyear: true, changeYear: true });
        $('#EndDate').datepicker({ dateFormat: 'yy/mm/dd', autoSize: true, showyear: true, changeYear: true });
        $("#SearchPanelHeader").click(function () { $("#SearchPanelBody").toggle(1000); });

        var commonColumns = [
            { field: "StringInsertDateTime", title: "تاریخ ثبت", width: "100px" },
            { field: "InvoiceNumber", title: "شماره فاکتور", width: "100px" },
            {
                field: "RequestState", title: "وضعیت بار", width: "130px",
                template: function (dataItem) {
                    if (dataItem.RequestState === 2) return "<span class='label label-success' style='font-size:12px;'>تایید مالی شده</span>";
                    if (dataItem.RequestState === 3) return "<span class='label label-info' style='font-size:12px;'>در جریان ارسال</span>";
                    if (dataItem.RequestState === 4) return "<span class='label label-primary' style='font-size:12px;'>تحویل داده شده</span>";
                    return "<span class='label label-default' style='font-size:12px;'>نامشخص</span>";
                }
            },
            { field: "Description", title: "توضیحات", width: "200px" },
            { field: "StringProductName", title: "نام محصول", width: "80px" },
            { field: "StringProductType", title: "تیپ محصول", width: "80px" }, // 🌟 اضافه شد
            { field: "StringPackageType", title: "نوع بسته‌بندی", width: "80px" },
            { field: "StringTonnage", title: "تناژ", width: "80px" },
            { field: "BuyerName", title: "نام مشتری", width: "150px" },
            { field: "BuyerMobile", title: "شماره گیرنده", width: "110px" },
            { field: "StringFactoryName", title: "مبدأ (کارخانه)", width: "100px" },
            { field: "Address", title: "آدرس مقصد", width: "200px" },
        ];



        // ------------------ گرید 1 ------------------
        var ds1 = new kendo.data.DataSource({
            pageSize: 10, serverPaging: true, serverSorting: true, serverFiltering: true,
            transport: {
                read: {
                    type: "POST", dataType: "json", url: "/Carrier/Request/Search",
                    data: function () {
                        var p = getSearchParameters(); p.gridTab = 1; return p;
                    }
                }
            },
            schema: { data: "Data", total: "Total" }
        });

        $("#grid1").kendoGrid({
            pageable: true, sortable: true, scrollable: true, dataSource: ds1,
            dataBinding: function () { rowNumber1 = (this.dataSource.page() - 1) * this.dataSource.pageSize(); },
            columns: [
                { title: "#", width: "40px", template: function () { return ++rowNumber1; } },
                {
                    title: "عملیات", width: "130px",
                    template: function (dataItem) {
                        var str = '<a title="نمایش" style="margin-left:8px;" href="/Carrier/Request/display/' + dataItem.Id + '"><img src="/Content/Icon/display.png" style="width:20px; height:20px;" /></a>';
                        str += '<a title="تخصیص راننده" style="margin-left:8px;" href="/Carrier/Request/Edit/' + dataItem.Id + '"><img src="/Content/Icon/edit.png" style="width:20px; height:20px;" /></a>';
                        str += "<a title='تغییر وضعیت به بارگیری شده' href='/Carrier/Request/LoadCargo/" + dataItem.Id + "'><svg xmlns='http://www.w3.org/2000/svg' width='24' height='24' fill='#5cb85c' viewBox='0 0 16 16'><path fill-rule='evenodd' d='M1 11.5a.5.5 0 0 0 .5.5h11.793l-3.147 3.146a.5.5 0 0 0 .708.708l4-4a.5.5 0 0 0 0-.708l-4-4a.5.5 0 0 0-.708.708L13.293 11H1.5a.5.5 0 0 0-.5.5zm14-7a.5.5 0 0 1-.5.5H2.707l3.147 3.146a.5.5 0 1 1-.708.708l-4-4a.5.5 0 0 1 0-.708l4-4a.5.5 0 1 1 .708.708L2.707 4H14.5a.5.5 0 0 1 .5.5z'/></svg></a>";
                        return str;
                    }
                }
            ].concat(commonColumns)
        });

        // ------------------ گرید 2 ------------------
        var ds2 = new kendo.data.DataSource({
            pageSize: 10, serverPaging: true, serverSorting: true, serverFiltering: true,
            transport: {
                read: {
                    type: "POST", dataType: "json", url: "/Carrier/Request/Search",
                    data: function () {
                        var p = getSearchParameters(); p.gridTab = 2; return p;
                    }
                }
            },
            schema: { data: "Data", total: "Total" }
        });

        $("#grid2").kendoGrid({
            autoBind: false,
            pageable: true, sortable: true, scrollable: true, dataSource: ds2,
            dataBinding: function () { rowNumber2 = (this.dataSource.page() - 1) * this.dataSource.pageSize(); },
            columns: [
                { title: "#", width: "40px", template: function () { return ++rowNumber2; } },
                {
                    title: "عملیات", width: "130px",
                    template: function (dataItem) {
                        var str = '<a title="نمایش" style="margin-left:8px;" href="/Carrier/Request/display/' + dataItem.Id + '"><img src="/Content/Icon/display.png" style="width:20px; height:20px;" /></a>';
                        if (dataItem.RequestState === 3) {
                            str += "<a title='ثبت تحویل نهایی' style='cursor:pointer;' onclick='setAsDelivered(\"" + dataItem.Id + "\")'><svg xmlns='http://www.w3.org/2000/svg' width='24' height='24' fill='#5cb85c' viewBox='0 0 16 16'><path d='M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z'/></svg></a>";
                        }
                        return str;
                    }
                }
            ].concat(commonColumns)
        });

        // ------------------ گرید 3 ------------------
        var ds3 = new kendo.data.DataSource({
            pageSize: 10, serverPaging: true, serverSorting: true, serverFiltering: true,
            transport: {
                read: {
                    type: "POST", dataType: "json", url: "/Carrier/Request/Search",
                    data: function () {
                        var p = getSearchParameters(); p.gridTab = 3; return p;
                    }
                }
            },
            schema: { data: "Data", total: "Total" }
        });

        $("#grid3").kendoGrid({
            autoBind: false,
            pageable: true, sortable: true, scrollable: true, dataSource: ds3,
            dataBinding: function () { rowNumber3 = (this.dataSource.page() - 1) * this.dataSource.pageSize(); },
            columns: [
                { title: "#", width: "40px", template: function () { return ++rowNumber3; } },
                {
                    title: "عملیات", width: "80px",
                    template: function (dataItem) {
                        return '<a title="نمایش جزئیات" href="/Carrier/Request/display/' + dataItem.Id + '"><img src="/Content/Icon/display.png" style="width:20px; height:20px;" /></a>';
                    }
                }
            ].concat(commonColumns)
        });

        // 🌟 دکمه جستجو: علاوه بر لود گرید، زمان‌ها را هم ریست می‌کند تا دیتای جدید بگیرد
        $("button#btnSearch").click(function () {
            var now = Date.now();

            $("#grid1").data("kendoGrid").dataSource.page(1);
            lastLoadTime1 = now;

            isGrid2Loaded = false;
            isGrid3Loaded = false;
            lastLoadTime2 = 0;
            lastLoadTime3 = 0;

            if ($("#tab2").parent().hasClass("active") || $("#tab2").hasClass("active")) {
                $("#grid2").data("kendoGrid").dataSource.page(1);
                isGrid2Loaded = true;
                lastLoadTime2 = now;
            }
            if ($("#tab3").parent().hasClass("active") || $("#tab3").hasClass("active")) {
                $("#grid3").data("kendoGrid").dataSource.page(1);
                isGrid3Loaded = true;
                lastLoadTime3 = now;
            }
        });

        // 🌟 مدیریت تغییر تب با قابلیت چک کردن زمان انقضا
        $('.nav-tabs a').on('click', function (e) {
            e.preventDefault();
            var target = $(this).attr("href");
            var now = Date.now();

            $('.nav-tabs li').removeClass('active');
            $(this).parent().addClass('active');

            $('.tab-content .tab-pane').removeClass('active');
            $(target).addClass('active');

            setTimeout(function () {
                if (target === "#tab1") {
                    var grid1 = $("#grid1").data("kendoGrid");
                    if (grid1) {
                        // اگر زمان گذشته بود، رفرش کن
                        if (now - lastLoadTime1 > cacheExpirationMs) {
                            grid1.dataSource.read();
                            lastLoadTime1 = now;
                        }
                        grid1.resize();
                    }
                }
                else if (target === "#tab2") {
                    var grid2 = $("#grid2").data("kendoGrid");
                    if (grid2) {
                        // اگر تا حالا لود نشده یا زمان منقضی شده
                        if (!isGrid2Loaded || (now - lastLoadTime2 > cacheExpirationMs)) {
                            grid2.dataSource.read();
                            isGrid2Loaded = true;
                            lastLoadTime2 = now;
                        }
                        grid2.resize();
                    }
                }
                else if (target === "#tab3") {
                    var grid3 = $("#grid3").data("kendoGrid");
                    if (grid3) {
                        // اگر تا حالا لود نشده یا زمان منقضی شده
                        if (!isGrid3Loaded || (now - lastLoadTime3 > cacheExpirationMs)) {
                            grid3.dataSource.read();
                            isGrid3Loaded = true;
                            lastLoadTime3 = now;
                        }
                        grid3.resize();
                    }
                }
            }, 100);
        });
    });

    function setAsDelivered(id) {
        if (confirm("آیا مطمئن هستید که بار تحویل مشتری داده شده است؟")) {
            $.post('/Carrier/Request/SetAsDelivered', { id: id }, function (result) {
                var isSuccess = result.success || result.Success;
                var msg = result.message || result.Message;
                if (isSuccess) {
                    if (typeof toastr !== 'undefined') toastr.success(msg); else alert(msg);
                    $("#grid2").data("kendoGrid").dataSource.read();
                    lastLoadTime2 = Date.now(); // آپدیت زمان لود پس از عملیات

                    if (isGrid3Loaded) {
                        $("#grid3").data("kendoGrid").dataSource.read();
                        lastLoadTime3 = Date.now();
                    }
                } else {
                    if (typeof toastr !== 'undefined') toastr.error(msg); else alert(msg);
                }
            });
        }
    }
</script>


<section id="Requests" class="form-horizontal" role="form">
    <br />
    <div class="panel panel-primary">
        <div class="panel-heading">مدیریت درخواست‌های باربری</div>
        <div class="col-md-12 panel-body">
            <a class="btn btn-default" data-toggle="tooltip" data-placement="top" title="@(Resources.Action.BackToMain)" href="/HomeMain/Main/" style="float: left;width:150px; margin-bottom: 15px;">
                <span style="float:right;">@Resources.Action.BackToMain</span><img style="float:left;" src='/Content/Icon/Back.png' />
            </a>
            <div style="clear:both;"></div>

            <ul class="nav nav-tabs" role="tablist">
                <li role="presentation" class="active">
                    <a href="#tab1" aria-controls="tab1" role="tab" data-toggle="tab">در انتظار بارگیری</a>
                </li>
                <li role="presentation">
                    <a href="#tab2" aria-controls="tab2" role="tab" data-toggle="tab">در جریان ارسال</a>
                </li>
                <li role="presentation">
                    <a href="#tab3" aria-controls="tab3" role="tab" data-toggle="tab">بایگانی (تحویل شده)</a>
                </li>
            </ul>

            <div class="tab-content" style="border: 1px solid #ddd; border-top: none; padding: 15px; border-radius: 0 0 5px 5px;">
                <div role="tabpanel" class="tab-pane active" id="tab1">
                    <div id="grid1" class="k-content k-rtl grid k-grid k-widget" style="width:100%;"></div>
                </div>
                <div role="tabpanel" class="tab-pane" id="tab2">
                    <div id="grid2" class="k-content k-rtl grid k-grid k-widget" style="width:100%;"></div>
                </div>
                <div role="tabpanel" class="tab-pane" id="tab3">
                    <div id="grid3" class="k-content k-rtl grid k-grid k-widget" style="width:100%;"></div>
                </div>
            </div>
        </div>
    </div>
</section>

