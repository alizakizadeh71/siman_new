@model ViewModels.Areas.Administrator.CarrierInventory.CarrierInventoryViewModel

@using (Html.BeginForm())
{
    <div class="panel panel-primary">

        <div class="panel-heading">
            افزایش موجودی باربری
        </div>

        <div class="panel-body">

            @Html.HiddenFor(x => x.Id)

            <div class="form-group">
                <label>باربری</label>
                <input class="form-control"
                       value="@Model.StringCarrierName"
                       readonly />
            </div>

            <div class="form-group">
                <label>محصول</label>
                <input class="form-control"
                       value="@Model.StringProductName"
                       readonly />
            </div>

            <div class="form-group">
                <label>نوع محصول</label>
                <input class="form-control"
                       value="@Model.StringProductType"
                       readonly />
            </div>

            <div class="form-group">
                <label>موجودی فعلی</label>

                <input class="form-control"
                       value="@Model.InventoryTonnage"
                       readonly />
            </div>

            <div class="form-group">
                <label>مقدار افزایش (تن)</label>

                <input type="number"
                       name="addedTonnage"
                       class="form-control"
                       min="0"
                       step="0.5" />
            </div>

            <button type="submit"
                    class="btn btn-success">
                افزایش موجودی
            </button>

        </div>

    </div>
}