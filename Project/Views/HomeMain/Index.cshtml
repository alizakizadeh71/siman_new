<script>
    function vmsblink(selector) {
        $(selector).fadeOut(500, function () {
            $(this).fadeIn(500, function () {
                vmsblink(this);
            });
        });
    }
    vmsblink('.blink');

</script>

<script type="text/javascript">
    function AllowNumbersOnly(e) {
        var code = (e.which) ? e.which : e.keyCode;
        if (code > 31 && (code < 48 || code > 57)) {
            e.preventDefault();
        }
    }

    function loadCarriersForPayment() {
        var productNameId = $("#ProductNameHidden").val();
        var productTypeId = $("#ProductTypeHidden").val();
        var packageTypeId = $("#PackageTypeHidden").val();
        var factoryNameId = $("#FactoryNameHidden").val();

        var empty = "00000000-0000-0000-0000-000000000000";
        if (!productNameId || productNameId === empty) return;
        if (!productTypeId || productTypeId === empty) return;
        if (!packageTypeId || packageTypeId === empty) return;
        if (!factoryNameId || factoryNameId === empty) return;

        $("#CarrierId").empty().append("<option value=''>در حال بارگذاری...</option>");

        $.ajax({
            url: '/Administrator/PreInvoice/GetCarriersByProduct',
            type: 'POST',
            data: {
                productNameId: productNameId,
                productTypeId: productTypeId,
                packageTypeId: packageTypeId,
                factoryNameId: factoryNameId
            },
            success: function (data) {
                var select = $("#CarrierId");
                select.empty();
                if (!data || data.length === 0) {
                    select.append("<option value=''>باربری برای این محصول تعریف نشده</option>");
                    return;
                }
                select.append("<option value=''>انتخاب باربری</option>");
                $.each(data, function (i, item) {
                    var text = item.IsDefault ? "⭐ " + item.Name + " (پیش‌فرض)" : item.Name;
                    var option = $('<option value="' + item.Id + '">' + text + '</option>');
                    if (item.IsDefault) {
                        option.prop('selected', true);
                    }
                    select.append(option);
                });
            },
            error: function () {
                $("#CarrierId").empty().append("<option value=''>خطا در بارگذاری</option>");
            }
        });
    }

    function toggleDriverFields() {
        if ($("#ShowDriverFields").is(":checked")) {
            $("#DriverFieldsSection").slideDown(250);
        } else {
            $("#DriverFieldsSection").slideUp(250);
            $("#DriverName").val("");
            $("#DriverMobile").val("");
        }
    }

    function onChangeProvince() {
        $.ajax({
            url: '/Administrator/HeadOfFactor/GetCities',
            type: 'post',
            data: {
                provinceId: $("#Province").val()
            },
            success: function (data) {
                $("#DivCityId").empty();
                var select = $("<select class='form-control' id='City' name='City' data-rel='chosen'>");
                select.append("<option value='@System.Guid.Empty'>از لیست انتخاب نمایید</option>");
                $.each(data, function (i, city) {
                    select.append('<option value="' + city.Id + '"> ' + city.Name + '</option>');
                });
                $("#DivCityId").append(select);
                $('#City>option:eq(1)').prop('selected', true);
                $("#City").attr("onchange", "onChangecity()");
            }
        });
    }

    function onChangeProductName() {
        $.ajax({
            url: '/Administrator/Cement/GetProductType',
            type: 'post',
            data: {
                ProductNameId: $("#ProductName").val()
            },
            success: function (data) {
                $("#DivProductTypeId").empty();
                var select = $("<select class='form-control' onchange='onChangeProductType()' id='ProductType' name='ProductType' data-rel='chosen'>");
                select.append("<option value='@System.Guid.Empty'>از لیست انتخاب نمایید</option>");
                $.each(data, function (i, ProductType) {
                    var option = ('<option value="' + ProductType.Id + '"> ' + ProductType.Name + '</option>');
                    if (i == 0) {
                        onChangeProductType(ProductType.Id);
                    }
                    select.append(option);
                });
                $("#DivProductTypeId").append(select);
                $('#ProductType>option:eq(1)').prop('selected', true);
            }
        });

        $.ajax({
            url: '/Administrator/Cement/GetFactoryName',
            type: 'post',
            data: {
                ProductNameId: $("#ProductName").val()
            },
            success: function (data) {
                $("#DivFactoryNameId").empty();
                var select = $("<select class='form-control' id='FactoryName' name='FactoryName' data-rel='chosen'>");
                select.append("<option value='@System.Guid.Empty'>از لیست انتخاب نمایید</option>");
                $.each(data, function (i, FactoryName) {
                    select.append('<option value="' + FactoryName.Id + '"> ' + FactoryName.Name + '</option>');
                });
                $("#DivFactoryNameId").append(select);
                $('#FactoryName>option:eq(1)').prop('selected', true);
            }
        });
    }

    function onChangeProductType(ProductTypee) {
        if (ProductTypee == undefined) {
            ProductTypee = $("#ProductType").val();
        }
        $.ajax({
            url: '/Administrator/Cement/GetPackageType',
            type: 'post',
            data: {
                ProductTypeId: ProductTypee
            },
            success: function (data) {
                $("#DivPackageTypeId").empty();
                var select = $("<select class='form-control' onchange='onChangePackageType()' id='PackageType' name='PackageType' data-rel='chosen'>");
                select.append("<option value='@System.Guid.Empty'>از لیست انتخاب نمایید</option>");
                $.each(data, function (i, PackageType) {
                    select.append('<option value="' + PackageType.Id + '"> ' + PackageType.Name + '</option>');
                });
                $("#DivPackageTypeId").append(select);
                $('#PackageType>option:eq(1)').prop('selected', true);
                if (typeof onChangePackageType === "function") {
                    onChangePackageType();
                }
            }
        });
    }

    function onChangecity() {
        $.ajax({
            url: '/Administrator/HeadOfFactor/GetVillage',
            type: 'post',
            data: {
                cityId: $("#City").val()
            },
            success: function (data) {
                $("#DivVillageId").empty();
                var select = $("<select class='form-control' id='village' name='village' data-rel='chosen'>");
                select.append("<option value='@System.Guid.Empty'>از لیست انتخاب نمایید</option>");
                $.each(data, function (i, village) {
                    select.append('<option value="' + village.Id + '"> ' + village.Name + '</option>');
                });
                $("#DivVillageId").append(select);
            }
        });
    }

    function EnablePayment() {
        var Karkhane = document.getElementById("Karkhane");
        var Mahal = document.getElementById("Mahal");
        if (Karkhane && Karkhane.checked == true) {
            $("#MahalTahvil").val('Karkhane');
        } else if (Mahal && Mahal.checked == true) {
            $("#MahalTahvil").val('Mahal');
        }

        setTimeout(function () {
            var btn = document.getElementById("btnPayment");
            if (btn) {
                btn.disabled = true;
                btn.value = "در حال پردازش...";
            }
        }, 100);
    }

    function copyLink() {
        var copyText = document.getElementById("linkInput");
        if (copyText) {
            copyText.select();
            document.execCommand("copy");
            alert("لینک کپی شد: " + copyText.value);
        }
    }

    $(document).ready(function () {
        if ($("#CarrierId").length > 0) {
            loadCarriersForPayment();
        }
    });

</script>
