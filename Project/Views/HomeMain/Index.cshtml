@model ViewModels.Areas.Administrator.Cement.CementViewModel
@{ ViewBag.Title = "Home Page"; }
<style>
    .example img {
        width: 100%;
        height: 300px;
    }

    .example::after {
        position: absolute;
        top: 100px;
        white-space: pre;
        right: 50%;
        transform: translateX(50%);
        font-weight: bold;
        font-size: 23px;
    }

    #loginFrom .row {
        width: 100%;
    }

    .panel-body #Mahal {
        margin-right: 6px;
        margin-left: 3px;
    }

    .disabled-purchase-box {
        margin-top: 40px;
        padding: 50px 20px;
        border-radius: 10px;
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
        background-color: #fdfdfd;
        border: 2px solid #ebccd1;
    }

    .carrier-box {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 20px;
        margin: 10px 0 15px 0;
    }

        .carrier-box .carrier-title {
            font-weight: bold;
            color: #fd7e14;
            margin-bottom: 15px;
            font-size: 15px;
            border-bottom: 1px solid #ffe0c4;
            padding-bottom: 8px;
        }

        .carrier-box .form-group {
            margin-bottom: 12px;
            clear: both;
            overflow: hidden;
        }

        .carrier-box label.control-label {
            text-align: right;
            padding-top: 8px;
        }
</style>

<div class="example">
    <img src="~/Content/Images/Baner1a.jpg" style="top: 0px; left: 0px; width: 100%; max-height: 100%; z-index: -10; border: solid; border-width: 7px; border-color: #e1e1e1; box-shadow: 0 7px 2px #777;" class="img-responsive">
</div>
<br />



@if (ViewBag.IsPurchaseEnabled != null && !(bool)ViewBag.IsPurchaseEnabled)
{
    <div class="row">
        <div class="col-md-8 col-md-offset-2">
            <div class="text-center disabled-purchase-box">
                <svg xmlns="http://www.w3.org/2000/svg" width="70" height="70" fill="#d9534f" viewBox="0 0 16 16" style="margin-bottom: 15px;">
                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" />
                    <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 4.995z" />
                </svg>
                <h2 style="color: #d9534f; margin-top: 25px; font-weight:bold;">
                    @(ViewBag.PageMessages is string ? ViewBag.PageMessages : "در حال حاضر امکان ثبت سفارش وجود ندارد.")
                </h2>
            </div>
        </div>
    </div> }
else
{
    <div class="row">
        <section id="loginFrom" class="col-md-12 col-md-offset-0 panel panel-info">

            @if (ViewBag.DisplaycreditAmount != null)
            {
                <h4 class="panel-heading" style="text-align:center; color:forestgreen">@ViewBag.DisplaycreditAmount</h4>}
            @if (ViewBag.Message != null)
            {
                <h4 class="panel-heading" style="text-align:center">@ViewBag.Message</h4>}

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.ErrorMessage
                </div>
            }

            @if (ViewBag.Karkhane != null && ViewBag.Karkhane != string.Empty)
            {
                using (Html.BeginForm("Payment", "Zarinpal", FormMethod.Post))
                {
                    <div style="color:red; text-align:center; font-weight:bold" class="panel-body">
                        <p style="color:black">لطفا محل تحویل را انتخاب نمایید</p>
                        @Html.RadioButtonFor(model => model.Description, "M", new { @id = "Karkhane", @checked = "checked" })
                        @Html.Raw(ViewBag.Karkhane)
                        <br />
                        @if (ViewBag.Mahal != null)
                        {
                            @Html.RadioButtonFor(model => model.Description, "F", new { @onclick = "EnablePayment()", @id = "Mahal" })
                            @Html.Raw(ViewBag.Mahal)
                            <br />}
                    </div>

                    @Html.Hidden("ProductNameHidden", Model.ProductName) @Html.Hidden("ProductTypeHidden", Model.ProductType) @Html.Hidden("PackageTypeHidden", Model.PackageType) @Html.Hidden("FactoryNameHidden", Model.FactoryName)
                    @Html.Hidden("invoiceNumber", Model.InvoiceNumber, new { @class = "form-controle" })
                    <!-- بخش باربری -->
                    <div class="panel-body" style="border-top: 1px solid #ddd; padding-top: 15px;">
                        <div class="carrier-box">
                            <div class="carrier-title">🚛 اطلاعات باربری</div>
                            <div class="form-horizontal">
                                <div class="form-group">
                                    <label class="col-md-3 control-label">باربری</label>
                                    <div class="col-md-6">
                                        <select id="CarrierId" name="CarrierId" class="form-control">
                                            <option value="">در حال بارگذاری...</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <div class="col-md-offset-3 col-md-6"> <label style="font-weight:normal; cursor:pointer;"> <input type="checkbox" id="ShowDriverFields" onchange="toggleDriverFields()" /> &nbsp;اطلاعات راننده را وارد کنم </label> </div>
                                </div>
                                <div id="DriverFieldsSection" style="display:none;">
                                    <div class="form-group">
                                        <label class="col-md-3 control-label">نام راننده</label>
                                        <div class="col-md-6"> <input type="text" id="DriverName" name="DriverName" class="form-control" placeholder="نام راننده" /> </div>
                                    </div>
                                    <div class="form-group">
                                        <label class="col-md-3 control-label">شماره تماس راننده</label>
                                        <div class="col-md-6"> <input type="text" id="DriverMobile" name="DriverMobile" class="form-control" placeholder="09xxxxxxxxx" onkeypress="return AllowNumbersOnly(event)" /> </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div> @Html.AntiForgeryToken() @Html.ValidationSummary(true) @Html.Hidden("invoiceNumber", null, new { @class = "form-controle" }) @Html.Hidden("MahalTahvil", null, new { @class = "form-controle" }) <div style="text-align:center; padding-bottom: 15px;"> <input class="btn btn-success" type="submit" id="btnPayment" style="margin-right:7px; text-align:center" value="پرداخت و دریافت فاکتور" onclick="EnablePayment()" /> </div> }
            }
            else if (ViewBag.PageMessages is string && !string.IsNullOrEmpty((string)ViewBag.PageMessages))
            { <div class="panel panel-info" style="text-align:center">
                    <div style="color:red; font-weight:bold" class="panel-body"> @Html.Raw((string)ViewBag.PageMessages) </div>
                </div>}

            @using (Html.BeginForm("Index", "HomeMain", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
            {@Html.AntiForgeryToken()
            <hr /> @Html.ValidationSummary(true) <div class="form-group">
                @Html.LabelFor(model => model.ProductName, new { @class = "col-md-3 control-label" }) <div class="col-md-6"> @Html.DropDownListFor(model => model.ProductName, null, Resources.Caption.SelectAnItem, new { @class = "form-control", @onchange = "onChangeProductName(); sendFormData();" }) @Html.ValidationMessageFor(model => model.ProductName) </div>
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.ProductType, new { @class = "col-md-3 control-label" }) <div class="col-md-6" id="DivProductTypeId"> @Html.DropDownListFor(model => model.ProductType, null, Resources.Caption.SelectAnItem, new { @class = "form-control", @onchange = "onChangeProductType(); sendFormData();" }) @Html.ValidationMessageFor(model => model.ProductType) </div>
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.PackageType, new { @class = "col-md-3 control-label" }) <div class="col-md-6" id="DivPackageTypeId"> @Html.DropDownListFor(model => model.PackageType, null, Resources.Caption.SelectAnItem, new { @class = "form-control", @onchange = "sendFormData();" }) @Html.ValidationMessageFor(model => model.PackageType) </div>
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.FactoryName, new { @class = "col-md-3 control-label" }) <div class="col-md-6" id="DivFactoryNameId"> @Html.DropDownListFor(model => model.FactoryName, null, Resources.Caption.SelectAnItem, new { @class = "form-control", @onchange = "sendFormData();" }) @Html.ValidationMessageFor(model => model.FactoryName) </div>
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.Tonnage, new { @class = "col-md-3 control-label" }) <div class="col-md-6" id="DivTonnageId"> @Html.TextBoxFor(model => model.Tonnage, new { @class = "form-control", onchange = "sendFormData();" }) @Html.ValidationMessageFor(model => model.Tonnage) </div>
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.BuyerFullName, new { @class = "col-md-3 control-label" }) <div class="col-md-6"> @Html.TextBoxFor(model => model.BuyerFullName, new { @class = "form-control" }) @Html.ValidationMessageFor(model => model.BuyerFullName) </div>
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.BuyerMobile, new { @class = "col-md-3 control-label" }) <div class="col-md-6"> @Html.TextBoxFor(model => model.BuyerMobile, new { @class = "form-control", @onkeypress = "return AllowNumbersOnly(event)" }) @Html.ValidationMessageFor(model => model.BuyerMobile) </div>
            </div>
            <div class="form-group">
                @Html.LabelFor(model => model.Description, new { @class = "col-md-3 control-label" }) <div class="col-md-6"> @Html.TextAreaFor(model => model.Description, new { @class = "form-control", Rows = 4, Style = "resize: none;" }) @Html.ValidationMessageFor(model => model.Description) </div>
            </div>
            <div class="form-group">
                <div class="text-center"> <input type="submit" value="محاسبه قیمت" class="btn btn-info" /> </div>
            </div>}
        </section>
    </div>}

<hr />
<div class="row">
    @Html.Action("News")
</div>

